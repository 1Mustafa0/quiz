{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "A collection of questions generated by AI or manually",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["multiple-choice", "true-false", "short-answer"] },
              "questionText": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "string" },
              "feedback": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorUid": { "type": "string" },
        "timer": { "type": "number", "description": "Timer in minutes" }
      },
      "required": ["title", "questions", "authorUid"]
    },
    "Result": {
      "title": "Result",
      "description": "The outcome of a quiz attempt",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "quizId": { "type": "string" },
        "userId": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "answers": { "type": "array", "items": { "type": "object" } },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["quizId", "userId", "score", "totalQuestions"]
    },
    "Todo": {
      "title": "Todo",
      "description": "A study task or reminder for the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] }
      },
      "required": ["userId", "text", "completed"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Quiz data"
    },
    "/results/{resultId}": {
      "schema": "Result",
      "description": "Quiz attempt results"
    },
    "/todos/{todoId}": {
      "schema": "Todo",
      "description": "User tasks and reminders"
    }
  }
}
